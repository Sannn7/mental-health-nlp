# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
ENV/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data — never commit raw or processed data ─────────────────────────────────
data/raw/*
data/processed/*
data/embeddings/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/embeddings/.gitkeep

# ── Outputs — never commit trained models or large result files ───────────────
outputs/models/*
outputs/results/*
outputs/visualizations/*
!outputs/models/.gitkeep
!outputs/results/.gitkeep
!outputs/visualizations/.gitkeep

# ── HuggingFace / model cache ─────────────────────────────────────────────────
*.bin
*.safetensors
*.pt
*.pth
*.ckpt

# ── Kaggle credentials ────────────────────────────────────────────────────────
kaggle.json
.env

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp